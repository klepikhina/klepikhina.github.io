diff --git a/_layouts/region.html b/_layouts/region.html
new file mode 100644
index 0000000..9a21c60
--- /dev/null
+++ b/_layouts/region.html
@@ -0,0 +1,86 @@
+---
+layout: default
+---
+
+<div class="page-header">
+  <h1>{{ page.title }}</h1>
+  {% if page.description %}
+  <p class="page-description">{{ page.description }}</p>
+  {% endif %}
+</div>
+
+{% if page.filter_regions %}
+  {% comment %} Filter by multiple regions (e.g., for International) {% endcomment %}
+  {% assign filtered_posts = "" | split: "" %}
+  {% for post in site.posts %}
+    {% for region in page.filter_regions %}
+      {% if post.region == region %}
+        {% assign filtered_posts = filtered_posts | push: post %}
+      {% endif %}
+    {% endfor %}
+  {% endfor %}
+{% else %}
+  {% comment %} Filter by single region {% endcomment %}
+  {% assign filtered_posts = site.posts | where: "region", page.filter_region %}
+{% endif %}
+
+{% if filtered_posts.size > 0 %}
+<div class="filter-pills">
+  <button class="filter-pill active" data-filter="all">All</button>
+  <button class="filter-pill filter-pill--bike" data-filter="bike_log">Bike</button>
+  <button class="filter-pill filter-pill--climb" data-filter="climb_log">Climb</button>
+  <button class="filter-pill filter-pill--hike" data-filter="hike_log">Hike</button>
+  <button class="filter-pill filter-pill--run" data-filter="run_log">Run</button>
+  <button class="filter-pill filter-pill--ski" data-filter="ski_log">Ski</button>
+</div>
+
+<div class="card-grid" id="region-grid">
+  {% for post in filtered_posts %}
+    {% if post.categories contains 'climb_log' %}
+      {% assign activity_class = "climb_log" %}
+    {% elsif post.categories contains 'bike_log' %}
+      {% assign activity_class = "bike_log" %}
+    {% elsif post.categories contains 'hike_log' %}
+      {% assign activity_class = "hike_log" %}
+    {% elsif post.categories contains 'run_log' %}
+      {% assign activity_class = "run_log" %}
+    {% elsif post.categories contains 'ski_log' %}
+      {% assign activity_class = "ski_log" %}
+    {% else %}
+      {% assign activity_class = "" %}
+    {% endif %}
+    <div class="adventure-item" data-activity="{{ activity_class }}">
+      {% include adventure-card.html post=post %}
+    </div>
+  {% endfor %}
+</div>
+{% else %}
+<div class="empty-state">
+  <div class="empty-state__icon">&#x1F3D4;</div>
+  <p class="empty-state__message">No adventures in {{ page.title }} yet. More coming soon!</p>
+</div>
+{% endif %}
+
+<script>
+document.addEventListener('DOMContentLoaded', function() {
+  const filterButtons = document.querySelectorAll('.filter-pill');
+  const adventureItems = document.querySelectorAll('.adventure-item');
+
+  filterButtons.forEach(button => {
+    button.addEventListener('click', function() {
+      const filter = this.getAttribute('data-filter');
+
+      filterButtons.forEach(btn => btn.classList.remove('active'));
+      this.classList.add('active');
+
+      adventureItems.forEach(item => {
+        if (filter === 'all' || item.getAttribute('data-activity') === filter) {
+          item.style.display = 'block';
+        } else {
+          item.style.display = 'none';
+        }
+      });
+    });
+  });
+});
+</script>
diff --git a/_sass/_cards.scss b/_sass/_cards.scss
new file mode 100644
index 0000000..ada3bd7
--- /dev/null
+++ b/_sass/_cards.scss
@@ -0,0 +1,308 @@
+//
+// CARD COMPONENTS
+//
+
+// ==========================================
+// Card Grid Layout
+// ==========================================
+.card-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
+  gap: 2rem;
+  padding: 1rem 0;
+
+  @include tablet {
+    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
+    gap: 1.5rem;
+  }
+
+  @include mobile {
+    grid-template-columns: 1fr;
+    gap: 1rem;
+  }
+}
+
+.card-grid--featured {
+  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
+
+  @include mobile {
+    grid-template-columns: 1fr;
+  }
+}
+
+// ==========================================
+// Adventure Card
+// ==========================================
+.adventure-card {
+  background: $cream;
+  border-radius: 12px;
+  overflow: hidden;
+  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
+  transition: transform 0.3s ease, box-shadow 0.3s ease;
+  display: flex;
+  flex-direction: column;
+
+  &:hover {
+    transform: translateY(-4px);
+    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
+  }
+
+  a {
+    text-decoration: none;
+    color: inherit;
+  }
+}
+
+// Card Image
+.adventure-card__image {
+  position: relative;
+  width: 100%;
+  height: 200px;
+  overflow: hidden;
+  background: $stone-light;
+
+  img {
+    width: 100%;
+    height: 100%;
+    object-fit: cover;
+    transition: transform 0.3s ease;
+  }
+
+  .adventure-card:hover & img {
+    transform: scale(1.05);
+  }
+}
+
+// Placeholder for posts without images
+.adventure-card__image--placeholder {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: linear-gradient(135deg, $forest-light 0%, $sky-light 100%);
+
+  .placeholder-icon {
+    font-size: 3rem;
+    opacity: 0.5;
+  }
+}
+
+// Activity Badge
+.adventure-card__badge {
+  position: absolute;
+  top: 12px;
+  left: 12px;
+  padding: 4px 12px;
+  border-radius: 20px;
+  font-size: 12px;
+  font-weight: 600;
+  text-transform: uppercase;
+  letter-spacing: 0.5px;
+  color: white;
+
+  &--climb { background: $color-climb; }
+  &--bike { background: $color-bike; }
+  &--hike { background: $color-hike; }
+  &--run { background: $color-run; }
+  &--ski { background: $color-ski; }
+}
+
+// Card Content
+.adventure-card__content {
+  padding: 1.25rem;
+  flex: 1;
+  display: flex;
+  flex-direction: column;
+}
+
+.adventure-card__title {
+  font-size: 1.1rem;
+  font-weight: 600;
+  color: $stone-dark;
+  margin: 0 0 0.5rem 0;
+  line-height: 1.4;
+}
+
+.adventure-card__location {
+  font-size: 0.9rem;
+  color: $stone-medium;
+  margin: 0 0 0.5rem 0;
+  display: flex;
+  align-items: center;
+  gap: 4px;
+
+  &::before {
+    content: "📍";
+    font-size: 0.8rem;
+  }
+}
+
+.adventure-card__date {
+  font-size: 0.85rem;
+  color: $stone-medium;
+  margin-top: auto;
+  padding-top: 0.75rem;
+  border-top: 1px solid $stone-light;
+}
+
+.adventure-card__excerpt {
+  font-size: 0.9rem;
+  color: $stone-medium;
+  line-height: 1.5;
+  margin: 0.5rem 0;
+  display: -webkit-box;
+  -webkit-line-clamp: 2;
+  -webkit-box-orient: vertical;
+  overflow: hidden;
+}
+
+// ==========================================
+// Region Filter Pills
+// ==========================================
+.filter-pills {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.5rem;
+  padding: 1rem 0;
+  margin-bottom: 1rem;
+}
+
+.filter-pill {
+  padding: 8px 16px;
+  border-radius: 20px;
+  border: 2px solid $forest-medium;
+  background: transparent;
+  color: $forest-medium;
+  font-size: 0.9rem;
+  font-weight: 500;
+  cursor: pointer;
+  transition: all 0.2s ease;
+
+  &:hover, &.active {
+    background: $forest-medium;
+    color: white;
+  }
+
+  &--climb.active { background: $color-climb; border-color: $color-climb; }
+  &--bike.active { background: $color-bike; border-color: $color-bike; }
+  &--hike.active { background: $color-hike; border-color: $color-hike; }
+  &--run.active { background: $color-run; border-color: $color-run; }
+  &--ski.active { background: $color-ski; border-color: $color-ski; }
+}
+
+// ==========================================
+// Section Headers
+// ==========================================
+.section-header {
+  margin: 2rem 0 1rem;
+  padding-bottom: 0.5rem;
+  border-bottom: 2px solid $forest-light;
+
+  h2 {
+    color: $forest-dark;
+    font-size: 1.5rem;
+    margin: 0;
+  }
+
+  .section-subtitle {
+    color: $stone-medium;
+    font-size: 0.95rem;
+    margin: 0.25rem 0 0;
+  }
+}
+
+// ==========================================
+// Currently Reading Card (for homepage)
+// ==========================================
+.book-card {
+  display: flex;
+  gap: 1rem;
+  padding: 1rem;
+  background: $cream;
+  border-radius: 8px;
+  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
+
+  &__cover {
+    width: 80px;
+    height: 120px;
+    flex-shrink: 0;
+
+    img {
+      width: 100%;
+      height: 100%;
+      object-fit: cover;
+      border-radius: 4px;
+    }
+  }
+
+  &__info {
+    flex: 1;
+  }
+
+  &__title {
+    font-size: 1rem;
+    font-weight: 600;
+    color: $stone-dark;
+    margin: 0 0 0.25rem;
+  }
+
+  &__author {
+    font-size: 0.9rem;
+    color: $stone-medium;
+    margin: 0;
+  }
+}
+
+// ==========================================
+// Creative Gallery Grid
+// ==========================================
+.gallery-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
+  gap: 1rem;
+
+  @include mobile {
+    grid-template-columns: 1fr 1fr;
+    gap: 0.5rem;
+  }
+}
+
+.gallery-item {
+  position: relative;
+  overflow: hidden;
+  border-radius: 8px;
+  aspect-ratio: 1;
+
+  img {
+    width: 100%;
+    height: 100%;
+    object-fit: cover;
+    transition: transform 0.3s ease;
+  }
+
+  &:hover img {
+    transform: scale(1.05);
+  }
+
+  &--wide {
+    grid-column: span 2;
+    aspect-ratio: 2/1;
+  }
+}
+
+// ==========================================
+// Empty State
+// ==========================================
+.empty-state {
+  text-align: center;
+  padding: 3rem 1rem;
+  color: $stone-medium;
+
+  &__icon {
+    font-size: 3rem;
+    margin-bottom: 1rem;
+  }
+
+  &__message {
+    font-size: 1.1rem;
+  }
+}
