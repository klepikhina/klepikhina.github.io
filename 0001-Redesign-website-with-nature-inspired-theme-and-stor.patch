+    document.getElementById("book-tree").innerHTML = '<p class="text-center">Could not load book data. Please try refreshing.</p>';
+  });
+})();
+
+// Book Statistics Charts
+(function() {
+  d3.json("{{ site.baseurl }}/js/books.json").then(function(data) {
+    // Calculate stats from data
+    const yearStats = [];
+    const formatStats = { audio: 0, physical: 0 };
+
+    data.children.forEach(yearNode => {
+      let yearTotal = 0;
+      yearNode.children.forEach(formatNode => {
+        const count = formatNode.children ? formatNode.children.length : 0;
+        yearTotal += count;
+        if (formatNode.name === 'audio') formatStats.audio += count;
+        else if (formatNode.name === 'physical') formatStats.physical += count;
+      });
+      yearStats.push({ year: yearNode.name, count: yearTotal });
+    });
+
+    // Books by Year - Bar Chart
+    const yearContainer = document.getElementById('books-by-year');
+    const yearWidth = Math.min(400, yearContainer.clientWidth);
+    const yearHeight = 200;
+    const margin = { top: 20, right: 20, bottom: 30, left: 40 };
+
+    const yearSvg = d3.select('#books-by-year')
+      .append('svg')
+      .attr('width', yearWidth)
+      .attr('height', yearHeight);
+
+    const xScale = d3.scaleBand()
+      .domain(yearStats.map(d => d.year))
+      .range([margin.left, yearWidth - margin.right])
+      .padding(0.2);
+
+    const yScale = d3.scaleLinear()
+      .domain([0, d3.max(yearStats, d => d.count) + 2])
+      .range([yearHeight - margin.bottom, margin.top]);
+
+    // Bars
+    yearSvg.selectAll('rect')
+      .data(yearStats)
+      .enter()
+      .append('rect')
+      .attr('x', d => xScale(d.year))
+      .attr('y', d => yScale(d.count))
+      .attr('width', xScale.bandwidth())
+      .attr('height', d => yearHeight - margin.bottom - yScale(d.count))
+      .attr('fill', '#4A7C59')
+      .attr('rx', 4);
+
+    // Labels on bars
+    yearSvg.selectAll('.bar-label')
+      .data(yearStats)
+      .enter()
+      .append('text')
+      .attr('class', 'bar-label')
+      .attr('x', d => xScale(d.year) + xScale.bandwidth() / 2)
+      .attr('y', d => yScale(d.count) - 5)
+      .attr('text-anchor', 'middle')
+      .attr('font-size', '12px')
+      .attr('fill', '#3D3D3D')
+      .text(d => d.count);
+
+    // X axis
+    yearSvg.append('g')
+      .attr('transform', `translate(0,${yearHeight - margin.bottom})`)
+      .call(d3.axisBottom(xScale))
+      .selectAll('text')
+      .attr('font-size', '11px');
+
+    // Title
+    yearSvg.append('text')
+      .attr('x', yearWidth / 2)
+      .attr('y', 12)
+      .attr('text-anchor', 'middle')
+      .attr('font-size', '14px')
+      .attr('font-weight', '600')
+      .attr('fill', '#2D5A3D')
+      .text('Books by Year');
+
+    // Format Donut Chart
+    const formatContainer = document.getElementById('books-by-format');
+    const formatWidth = Math.min(250, formatContainer.clientWidth);
+    const formatHeight = 200;
+    const formatRadius = Math.min(formatWidth, formatHeight) / 2 - 20;
+
+    const formatSvg = d3.select('#books-by-format')
+      .append('svg')
+      .attr('width', formatWidth)
+      .attr('height', formatHeight)
+      .append('g')
+      .attr('transform', `translate(${formatWidth/2},${formatHeight/2 + 10})`);
+
+    const formatData = [
+      { name: 'Physical', value: formatStats.physical, color: '#4A7C59' },
+      { name: 'Audio', value: formatStats.audio, color: '#4A90A4' }
+    ];
+
+    const pie = d3.pie().value(d => d.value).sort(null);
+    const arc = d3.arc().innerRadius(formatRadius * 0.5).outerRadius(formatRadius);
+
+    const arcs = formatSvg.selectAll('.arc')
+      .data(pie(formatData))
+      .enter()
+      .append('g')
+      .attr('class', 'arc');
+
+    arcs.append('path')
+      .attr('d', arc)
+      .attr('fill', d => d.data.color)
+      .attr('stroke', 'white')
+      .attr('stroke-width', 2);
+
+    // Legend
+    const legend = formatSvg.selectAll('.legend')
+      .data(formatData)
+      .enter()
+      .append('g')
+      .attr('class', 'legend')
+      .attr('transform', (d, i) => `translate(${formatRadius + 10},${-20 + i * 22})`);
+
+    legend.append('rect')
+      .attr('width', 14)
+      .attr('height', 14)
+      .attr('fill', d => d.color)
+      .attr('rx', 2);
+
+    legend.append('text')
+      .attr('x', 20)
+      .attr('y', 11)
+      .attr('font-size', '12px')
+      .attr('fill', '#3D3D3D')
+      .text(d => `${d.name}: ${d.value}`);
+
+    // Center text
+    formatSvg.append('text')
+      .attr('text-anchor', 'middle')
+      .attr('dy', '0.35em')
+      .attr('font-size', '20px')
+      .attr('font-weight', '600')
+      .attr('fill', '#2D5A3D')
+      .text(formatStats.audio + formatStats.physical);
+
+    // Title
+    d3.select('#books-by-format svg')
+      .append('text')
+      .attr('x', formatWidth / 2)
+      .attr('y', 12)
+      .attr('text-anchor', 'middle')
+      .attr('font-size', '14px')
+      .attr('font-weight', '600')
+      .attr('fill', '#2D5A3D')
+      .text('Books by Format');
+
+  }).catch(function(error) {
+    console.error("Error loading books data for stats:", error);
+  });
+})();
 </script>
