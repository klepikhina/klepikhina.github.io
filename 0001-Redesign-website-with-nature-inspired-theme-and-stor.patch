+        .attr("transform", d => `rotate(${source.x0 * 180 / Math.PI - 90}) translate(${source.y0},0)`)
+        .on("click", (event, d) => {
+          // If it's a book (has value/link), open Amazon
+          if (d.data.value && d.data.value.length > 0) {
