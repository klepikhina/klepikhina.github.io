diff --git a/_includes/adventure-card.html b/_includes/adventure-card.html
new file mode 100644
index 0000000..52dee37
--- /dev/null
+++ b/_includes/adventure-card.html
@@ -0,0 +1,61 @@
+{% comment %}
+Adventure Card Component
+Usage: {% include adventure-card.html post=post %}
+{% endcomment %}
+
+<article class="adventure-card">
+  <a href="{{ site.baseurl }}{{ include.post.url }}">
+    <div class="adventure-card__image{% unless include.post.featured_image %} adventure-card__image--placeholder{% endunless %}">
+      {% if include.post.featured_image %}
+        <img src="{{ include.post.featured_image }}" alt="{{ include.post.title }}" loading="lazy">
+      {% else %}
+        <span class="placeholder-icon">
+          {% case include.post.activity %}
+            {% when 'climb' %}
+              &#x26F0;
+            {% when 'bike' %}
+              &#x1F6B2;
+            {% when 'hike' %}
+              &#x1F3D4;
+            {% when 'run' %}
+              &#x1F3C3;
+            {% when 'ski' %}
+              &#x26F7;
+            {% else %}
+              &#x1F30D;
+          {% endcase %}
+        </span>
+      {% endif %}
+
+      {% if include.post.activity %}
+        <span class="adventure-card__badge adventure-card__badge--{{ include.post.activity }}">
+          {{ include.post.activity | capitalize }}
+        </span>
+      {% elsif include.post.categories contains 'climb_log' %}
+        <span class="adventure-card__badge adventure-card__badge--climb">Climb</span>
+      {% elsif include.post.categories contains 'bike_log' %}
+        <span class="adventure-card__badge adventure-card__badge--bike">Bike</span>
+      {% elsif include.post.categories contains 'hike_log' %}
+        <span class="adventure-card__badge adventure-card__badge--hike">Hike</span>
+      {% elsif include.post.categories contains 'run_log' %}
+        <span class="adventure-card__badge adventure-card__badge--run">Run</span>
+      {% elsif include.post.categories contains 'ski_log' %}
+        <span class="adventure-card__badge adventure-card__badge--ski">Ski</span>
+      {% endif %}
+    </div>
+
+    <div class="adventure-card__content">
+      <h3 class="adventure-card__title">{{ include.post.title | split: ' | ' | first }}</h3>
+
+      {% if include.post.location %}
+        <p class="adventure-card__location">{{ include.post.location }}{% if include.post.region %}, {{ include.post.region }}{% endif %}</p>
+      {% endif %}
+
+      {% if include.show_excerpt %}
+        <p class="adventure-card__excerpt">{{ include.post.excerpt | strip_html | truncate: 100 }}</p>
+      {% endif %}
+
+      <p class="adventure-card__date">{{ include.post.date | date: "%B %e, %Y" }}</p>
+    </div>
+  </a>
+</article>
diff --git a/_includes/map-data.html b/_includes/map-data.html
new file mode 100644
index 0000000..4b47c2d
--- /dev/null
+++ b/_includes/map-data.html
@@ -0,0 +1,34 @@
+{% comment %}
+Generates JSON data for the adventure map from posts with coordinates
+{% endcomment %}
+<script>
+var adventureData = [
+{% assign activity_posts = site.posts | where_exp: "post", "post.latitude" %}
+{% for post in activity_posts %}
+  {% if post.categories contains 'climb_log' %}
+    {% assign activity = "climb" %}
+  {% elsif post.categories contains 'bike_log' %}
+    {% assign activity = "bike" %}
+  {% elsif post.categories contains 'hike_log' %}
+    {% assign activity = "hike" %}
+  {% elsif post.categories contains 'run_log' %}
+    {% assign activity = "run" %}
+  {% elsif post.categories contains 'ski_log' %}
+    {% assign activity = "ski" %}
+  {% else %}
+    {% assign activity = "" %}
+  {% endif %}
+  {
+    "title": {{ post.title | split: ' | ' | first | jsonify }},
+    "url": "{{ site.baseurl }}{{ post.url }}",
+    "location": {{ post.location | jsonify }},
+    "region": {{ post.region | jsonify }},
+    "country": {{ post.country | jsonify }},
+    "latitude": {{ post.latitude }},
+    "longitude": {{ post.longitude }},
+    "activity": "{{ activity }}",
+    "date": "{{ post.date | date: '%Y-%m-%d' }}"
+  }{% unless forloop.last %},{% endunless %}
+{% endfor %}
+];
+</script>
