@@ -0,0 +1,52 @@
+---
+layout: default
+title: Writing
+permalink: /writing/
+---
+
+<div class="page-header">
+  <h1>Writing</h1>
+  <p class="page-description">Essays, stories, and reflections</p>
+</div>
+
+{% assign blog_posts = site.posts | where_exp: "post", "post.categories contains 'blog' or post.categories == empty" %}
+{% assign has_posts = false %}
+{% for post in site.posts %}
+  {% unless post.categories contains 'climb_log' or post.categories contains 'bike_log' or post.categories contains 'hike_log' or post.categories contains 'run_log' or post.categories contains 'ski_log' %}
+    {% assign has_posts = true %}
+    {% break %}
+  {% endunless %}
+{% endfor %}
+
+{% if has_posts %}
+<div class="writing-list">
+  {% for post in site.posts %}
+    {% unless post.categories contains 'climb_log' or post.categories contains 'bike_log' or post.categories contains 'hike_log' or post.categories contains 'run_log' or post.categories contains 'ski_log' %}
+    <article class="post-item">
+      <h2 class="post-title">
+        <a href="{{ site.baseurl }}{{ post.url }}">{{ post.title }}</a>
+      </h2>
+      <p class="post-meta">
+        <time datetime="{{ post.date | date: '%Y-%m-%d' }}">{{ post.date | date: "%B %e, %Y" }}</time>
+        {% if post.categories.size > 0 %}
+          <span class="post-categories">
+            {% for category in post.categories %}
+              <span class="category-tag">{{ category }}</span>
+            {% endfor %}
+          </span>
+        {% endif %}
+      </p>
+      {% if post.excerpt %}
+      <p class="post-excerpt">{{ post.excerpt | strip_html | truncate: 200 }}</p>
+      {% endif %}
+    </article>
+    {% endunless %}
+  {% endfor %}
+</div>
+{% else %}
+<div class="empty-state">
+  <div class="empty-state__icon">&#x270D;</div>
+  <p class="empty-state__message">Writing section coming soon.</p>
+  <p style="color: #666; margin-top: 1rem;">In the meantime, explore the <a href="{{ site.baseurl }}/adventures/">adventure logs</a> for trip reports and stories from the trail.</p>
+</div>
