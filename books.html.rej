+  function renderBookshelf() {
+    bookshelfContainer.innerHTML = allBooks.map(yearData => {
+      const filteredBooks = currentFilter === 'all'
+        ? yearData.books
+        : yearData.books.filter(b => b.format === currentFilter);
+
+      if (filteredBooks.length === 0) return '';
+
+      return `
+        <div class="bookshelf-year" data-year="${yearData.year}">
+          <div class="bookshelf-year__header" onclick="toggleYear('${yearData.year}')">
+            <h3 class="bookshelf-year__title">${yearData.year}</h3>
+            <span class="bookshelf-year__count">${filteredBooks.length} books</span>
+            <span class="bookshelf-year__toggle">▼</span>
+          </div>
+          <div class="bookshelf-grid">
+            ${filteredBooks.map(book => {
+              const match = book.name.match(/"([^"]+)",\s*(.+)/);
+              const title = match ? match[1] : book.name;
+              const author = match ? match[2] : '';
+              // Use Goodreads book ID if available, otherwise search by title
+              const goodreadsUrl = book.value
+                ? `https://www.goodreads.com/book/show/${book.value}`
+                : `https://www.goodreads.com/search?q=${encodeURIComponent(title + ' ' + author)}`;
+
+              return `
+                <div class="bookshelf-book"
+                     data-title="${title.replace(/"/g, '&quot;')}"
+                     data-author="${author.replace(/"/g, '&quot;')}"
+                     data-format="${book.format}"
+                     onclick="window.open('${goodreadsUrl}', '_blank')">
+                  <img src="${book.image}" alt="${title}" loading="lazy">
+                  <span class="bookshelf-book__format bookshelf-book__format--${book.format}"
+                        title="${book.format}">
+                    ${book.format === 'audio' ? '🎧' : '📖'}
+                  </span>
+                </div>
+              `;
+            }).join('')}
+          </div>
+        </div>
+      `;
+    }).join('');
+
+    // Setup hover tooltips
+    document.querySelectorAll('.bookshelf-book').forEach(book => {
+      book.addEventListener('mouseenter', showTooltip);
+      book.addEventListener('mouseleave', hideTooltip);
+      book.addEventListener('mousemove', moveTooltip);
+    });
+  }
+
+  function setupFilters() {
+    document.querySelectorAll('.bookshelf-filters .filter-pill').forEach(btn => {
+      btn.addEventListener('click', () => {
+        document.querySelectorAll('.bookshelf-filters .filter-pill').forEach(b => b.classList.remove('active'));
+        btn.classList.add('active');
+        currentFilter = btn.dataset.filter;
+        renderBookshelf();
+      });
+    });
+  }
+
+  function showTooltip(e) {
+    const book = e.currentTarget;
+    tooltip.innerHTML = `
+      <div class="title">${book.dataset.title}</div>
+      <div class="author">${book.dataset.author}</div>
+      <div class="format">${book.dataset.format}</div>
+    `;
+    tooltip.classList.add('visible');
+  }
+
+  function hideTooltip() {
+    tooltip.classList.remove('visible');
+  }
+
+  function moveTooltip(e) {
+    tooltip.style.left = (e.clientX + 15) + 'px';
+    tooltip.style.top = (e.clientY + 15) + 'px';
+  }
+
+  // Global function for year toggle
+  window.toggleYear = function(year) {
+    const yearEl = document.querySelector(`.bookshelf-year[data-year="${year}"]`);
+    yearEl.classList.toggle('collapsed');
+  };
 })();
+</script>
 
